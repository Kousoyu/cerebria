{
  "name": "cerebria",
  "version": "1.2.0",
  "description": "A local-first, governed, recoverable agent runtime",
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./package.json": "./package.json"
  },
  "scripts": {
    "test": "jest",
    "test:coverage": "jest --coverage",
    "lint": "eslint -c .eslintrc.json src/**/*.ts tests/**/*.ts",
    "build": "tsc",
    "start": "ts-node examples/basic_usage.ts",
    "dev": "ts-node-dev --respawn --transpile-only examples/basic_usage.ts",
    "dev:recovery": "ts-node examples/recovery_demo.ts",
    "docker:build": "docker build -t cerebria .",
    "docker:run": "docker run --rm -it -p 3000:3000 -v $(pwd)/data:/app/data cerebria",
    "install-deps": "npm install better-sqlite3"
  },
  "keywords": [
    "agent-runtime",
    "cognitive-kernel",
    "local-first",
    "governance",
    "recovery",
    "ai",
    "runtime"
  ],
  "author": "Kousoyu",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Kousoyu/cerebria.git"
  },
  "homepage": "https://github.com/Kousoyu/cerebria#readme",
  "bugs": {
    "url": "https://github.com/Kousoyu/cerebria/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist/",
    "config/",
    "examples/",
    "docs/",
    "LICENSE",
    "README.md"
  ],
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "jest-util": "^30.3.0",
    "limbicdb": "^1.0.1",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^6.0.2"
  },
  "optionalDependencies": {
    "better-sqlite3": "^9.6.0"
  },
  "peerDependencies": {
    "limbicdb": "^1.0.1"
  }
}
