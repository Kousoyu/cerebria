{
  "name": "cerebria",
  "version": "0.1.0-alpha.3",
  "description": "The Cognitive Core for Autonomous Agents",
  "main": "index.js",
  "exports": {
    ".": "./index.js",
    "./package.json": "./package.json"
  },
  "scripts": {
    "test": "jest",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/**/*.js tests/**/*.js",
    "build": "tsc",
    "start": "node examples/basic_usage.js",
    "dev": "node --watch examples/basic_usage.js",
    "docker:build": "docker build -t cerebria .",
    "docker:run": "docker run --rm -it -p 3000:3000 -v $(pwd)/data:/app/data cerebria",
    "install-deps": "npm install better-sqlite3"
  },
  "keywords": [
    "agent-runtime",
    "cognitive-kernel",
    "local-first",
    "governance",
    "recovery",
    "ai",
    "runtime"
  ],
  "author": "Kousoyu",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Kousoyu/cerebria.git"
  },
  "homepage": "https://github.com/Kousoyu/cerebria#readme",
  "bugs": {
    "url": "https://github.com/Kousoyu/cerebria/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "index.js",
    "src/",
    "dist/",
    "config/",
    "examples/",
    "docs/",
    "LICENSE",
    "README.md"
  ],
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "limbicdb": "^1.0.0-beta.1",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2"
  },
  "optionalDependencies": {
    "better-sqlite3": "^9.6.0"
  },
  "peerDependencies": {
    "limbicdb": "^1.0.0-beta.1"
  }
}
