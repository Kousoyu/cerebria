{
  "dataDir": "./data",
  "mode": "standard",
  "logging": {
    "level": "INFO",
    "asyncWrite": true,
    "batchSize": 10,
    "flushInterval": 5000
  },
  "backup": {
    "maxBackups": 10,
    "schedule": "0 2 * * *",
    "validateBeforeUse": true
  },
  "taskManagement": {
    "defaultTimeout": 7200,
    "maxRetries": 3,
    "cacheSize": 50
  }
}
